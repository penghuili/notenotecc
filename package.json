{
  "name": "notenotecc",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@douyinfe/semi-ui": "2.68.3",
    "@remixicon/react": "4.4.0",
    "@semi-bot/semi-theme-notenotecc": "1.0.1",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "file-saver": "2.0.5",
    "idb-keyval": "6.2.1",
    "inobounce": "0.2.1",
    "jwt-decode": "4.0.0",
    "lodash.uniqby": "4.7.0",
    "openpgp": "5.11.2",
    "qrcode.react": "3.1.0",
    "ramda": "0.30.1",
    "react": "18.3.1",
    "react-baby-router": "0.2.2",
    "react-dom": "18.3.1",
    "react-error-boundary": "4.0.13",
    "react-fast-memo": "2.0.1",
    "styled-components": "5.3.11",
    "usecat": "1.1.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.3",
    "dotenv": "16.4.5",
    "eslint": "8.57.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-sonarjs": "1.0.4",
    "prettier": "3.3.3",
    "rollup-plugin-visualizer": "5.12.0",
    "vite": "5.4.10",
    "vite-plugin-semi-theme": "0.6.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "time": "sudo ntpdate time.nist.gov",
    "cc": "node scripts/commit.js",
    "cs": "powershell -NoProfile -Command \"if (Test-Path src/shared) { Remove-Item -LiteralPath src/shared -Recurse -Force }; New-Item -ItemType Directory -Force src/shared | Out-Null; Copy-Item -Recurse ../private-sharedjs/lib/js src/shared/js; Copy-Item -Recurse ../private-sharedjs/lib/browser src/shared/browser; Copy-Item -Recurse ../private-sharedjs/lib/semi src/shared/semi\"",
    "start": "npm run cs && vite",
    "build": "vite build",
    "dt": "node ./scripts/update-build-env.js dev && node ./scripts/upload.js",
    "dp": "node ./scripts/update-build-env.js prod && node ./scripts/upload.js",
    "lint": "eslint .",
    "ana": "vite --profile",
    "rr": "node scripts/react-versions.js"
  }
}
